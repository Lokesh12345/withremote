# =============================================================================
# syncpipe — environment configuration
# Copy this file to `.env` and fill in the blanks.
#   cp .env.example .env
#
# NOTHING here is required to run the pipeline in FAKE mode (--fake), which is
# how the demo scripts run. You only need these filled to hit the REAL APIs.
# =============================================================================

# ---- General -----------------------------------------------------------------
# Where the SQLite database file lives.
SYNC_DB_PATH=./syncpipe.db

# Default data mode when a CLI/flag does not override it: "live" or "fake".
# "fake" serves local fixtures and never touches the network.
SYNC_MODE=fake

# ---- HubSpot (CRM source) ----------------------------------------------------
# Private App access token from https://developers.hubspot.com
# Create a private app in your test account and grant crm.objects.contacts.read.
HUBSPOT_ACCESS_TOKEN=

# Client secret of the HubSpot app — used to verify webhook signatures (v3).
HUBSPOT_WEBHOOK_SECRET=

# ---- Stripe (payments source) ------------------------------------------------
# Secret key in TEST mode (starts with sk_test_...) from
# https://dashboard.stripe.com/test/apikeys
STRIPE_API_KEY=

# Webhook signing secret (starts with whsec_...) from the webhook endpoint
# you register in the Stripe dashboard, or from `stripe listen`.
STRIPE_WEBHOOK_SECRET=

# ---- Google Calendar (events source) -----------------------------------------
# Which calendar to sync. "primary" is the account's default calendar,
# or paste a specific calendar id (…@group.calendar.google.com).
GOOGLE_CALENDAR_ID=primary

# Path to the OAuth client secrets JSON downloaded from Google Cloud Console
# (APIs & Services > Credentials > OAuth client ID, Desktop app).
GOOGLE_CREDENTIALS_FILE=./google_credentials.json

# Path where the pipeline caches the user OAuth token after first consent.
GOOGLE_TOKEN_FILE=./google_token.json

# Shared token echoed back on Google push notifications, used to
# authenticate incoming calendar webhooks.
GOOGLE_WEBHOOK_TOKEN=

# ---- Webhook receiver --------------------------------------------------------
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
